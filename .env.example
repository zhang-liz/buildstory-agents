# Copy to .env.local and fill in real values:
#   cp .env.example .env.local

# Required
OPENAI_API_KEY=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Optional — OpenAI chat model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional — Upstash Redis for distributed rate limits (otherwise in-memory)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
