{
  "name": "buildstory-agents",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "bunx tsc --noEmit && bunx eslint .",
    "format": "bunx biome format --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "cd developer-docs && bun run start",
    "docs:build": "cd developer-docs && bun run build",
    "docs:serve": "cd developer-docs && bun run serve"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "@upstash/redis": "^1.37.0",
    "@vercel/kv": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "jotai": "^2.19.0",
    "lucide-react": "^0.475.0",
    "next": "16.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "same-runtime": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.2",
    "@vitest/ui": "^4.0.2",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0",
    "vitest": "^4.0.2"
  }
}
