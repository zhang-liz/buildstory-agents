# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
developer-docs/node_modules
/.pnp
.pnp.*
package-lock.json
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# environment variables (keep .env.example committed as a template)
.env
.env.local
.env.*.local

# production
/build
developer-docs/build
developer-docs/.docusaurus

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# other env files — do not use a bare `.env*` here or `.env.example` cannot be tracked
.env.development
.env.production
.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local directories
.claude
.same/
